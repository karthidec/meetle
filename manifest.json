{
  "manifest_version": 3,
  "name": "Meetle — Smart Meeting Points",
  "short_name": "Meetle",
  "version": "1.0.0",
  "description": "Find the fairest meeting spot for any group — smart routing, real traffic, worldwide.",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "Open Meetle",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": ["tabs"]
}
